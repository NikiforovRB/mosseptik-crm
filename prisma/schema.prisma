generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(cuid())
  username          String          @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole        @default(MANAGER)
  avatarOriginalKey String?
  avatarWebpKey     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  assignedClients   Client[]        @relation("ClientAssignee")
  communications    Communication[] @relation("CommunicationAuthor")
  nextTasksAssigned ClientNextTask[] @relation("NextTaskAssignee")
}

model Funnel {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  stages    FunnelStage[]
}

model FunnelStage {
  id          String   @id @default(cuid())
  funnelId    String
  name        String
  order       Int
  headerColor String   @default("#ccd0e1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clients     Client[]
  funnel      Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@unique([funnelId, order])
  @@index([funnelId])
}

model SepticModel {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]
}

model Client {
  id                  String          @id @default(cuid())
  firstName           String
  lastName            String
  middleName          String?
  phone               String?
  shortComment        String          @default("")
  requisites          String          @default("")
  septicModelId       String?
  funnelStageId       String
  orderInStage        Int             @default(0)
  assignedManagerId   String?
  qualified           Boolean?
  moneyProgress       MoneyProgress?
  gsoType             GsoType?
  isUrgent            Boolean         @default(false)
  isDealDeleted       Boolean         @default(false)
  lastCommunicationAt DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  assignedManager     User?           @relation("ClientAssignee", fields: [assignedManagerId], references: [id])
  funnelStage         FunnelStage     @relation(fields: [funnelStageId], references: [id])
  septicModel         SepticModel?    @relation(fields: [septicModelId], references: [id])
  communications      Communication[]
  nextTask            ClientNextTask?

  @@index([funnelStageId, orderInStage])
  @@index([assignedManagerId])
}

model ClientNextTask {
  id         String    @id @default(cuid())
  clientId   String    @unique
  dueAt      DateTime?
  dueHasTime Boolean   @default(false)
  assigneeId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignee   User      @relation("NextTaskAssignee", fields: [assigneeId], references: [id])

  @@index([assigneeId])
}

model Communication {
  id                String               @id @default(cuid())
  clientId          String
  authorId          String
  kind              CommunicationKind    @default(STANDARD)
  taskAssigneeLabel String?
  text              String               @default("")
  createdAt         DateTime             @default(now())
  communicationDate DateTime
  author            User                 @relation("CommunicationAuthor", fields: [authorId], references: [id])
  client            Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  photos            CommunicationPhoto[]

  @@index([clientId, createdAt])
}

model CommunicationPhoto {
  id              String        @id @default(cuid())
  communicationId String
  originalKey     String
  webpKey         String
  createdAt       DateTime      @default(now())
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@index([communicationId])
}

enum UserRole {
  ADMIN
  MANAGER
}

enum MoneyProgress {
  ASSIGNED
  CONFIRMED
  DONE_WITH_MONEY
  DONE_WITHOUT_MONEY
}

enum GsoType {
  GSO1
  GSO2
}

enum CommunicationKind {
  STANDARD
  TASK_COMPLETED
}
